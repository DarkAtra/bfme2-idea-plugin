<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>de.darkatra.bfme2.bfme2-idea-plugin</id>
    <name>Sage Engine INI</name>
    <vendor url="https://darkatra.dev">DarkAtra</vendor>
    <description>Language support for Sage Engine Ini files.</description>

    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Sage Engine Ini" implementationClass="de.darkatra.bfme2.ini.SageEngineIniFileType"
                  fieldName="INSTANCE" language="SageEngineIni" extensions="ini"/>
        <lang.parserDefinition language="SageEngineIni"
                               implementationClass="de.darkatra.bfme2.ini.SageEngineIniParserDefinition"/>
        <lang.syntaxHighlighterFactory language="SageEngineIni"
                                       implementationClass="de.darkatra.bfme2.ini.highlighting.SageEngineIniSyntaxHighlighterFactory"/>
        <lang.commenter language="SageEngineIni" implementationClass="de.darkatra.bfme2.ini.SageEngineIniCommenter"/>
        <lang.formatter language="SageEngineIni"
                        implementationClass="de.darkatra.bfme2.ini.formatting.SageEngineIniFormattingModelBuilder"/>
        <preFormatProcessor implementation="de.darkatra.bfme2.ini.formatting.SageEngineIniPreFormatProcessor"/>
    </extensions>
    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>
</idea-plugin>
